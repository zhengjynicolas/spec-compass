{
  "config": {
    "name": "project-a",
    "baseURL": "http://localhost:3000",
    "vitest": {
      "include": [
        "tests/unit/**/*.test.ts"
      ],
      "command": "echo",
      "args": [
        "vitest demo executed"
      ],
      "passWithNoTests": true
    },
    "playwright": {
      "testDir": "tests/e2e",
