      "headless": true,
      "trace": "on-first-retry"
    },
    "coverage": {
      "enabled": true,
      "provider": "v8",
      "reportsDirectory": "coverage",
      "reporter": [
        "text",
        "html",
        "json-summary"
      ],
      "clean": true,
      "reportOnFailure": true
    },
    "artifacts": {
      "outputDir": ".speccompass/artifacts",
      "screenshot": "only-on-failure",
      "video": "retain-on-failure",
      "trace": "on-first-retry"
    },
    "results": {
      "outputDir": "test-results"
    }
  },
