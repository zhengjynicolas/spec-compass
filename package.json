{
  "name": "spec-compass",
  "version": "0.2.1",
  "description": "SpecCompass is a lightweight Vitest and Playwright init/run kernel for host projects.",
  "private": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "docs",
    "examples/project-a/package.json",
    "examples/project-a/playwright.speccompass.config.ts",
    "examples/project-a/tests",
    "examples/project-a/vitest.speccompass.config.ts",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "bin": {
    "speccompass": "dist/cli/index.js"
  },
  "keywords": [
    "testing",
    "typescript",
    "vitest",
    "playwright",
    "cli",
    "npm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhengjynicolas/spec-compass.git"
  },
  "bugs": {
    "url": "https://github.com/zhengjynicolas/spec-compass/issues"
  },
  "homepage": "https://github.com/zhengjynicolas/spec-compass#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/cli/index.js run",
    "test": "vitest run --config tests/vitest/config.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@vitest/coverage-v8": "^3.2.4"
  }
}
